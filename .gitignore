# ##############################################################################
# Gitignore template for static HTML/CSS/JS web projects
# Includes standard Node.js, Python (dev server), OS, and IDE exclusions
# ##############################################################################

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Optional npm/yarn cache directory
.npm
.yarn/
.eslintcache
.stylelintcache

# Environment variables & secrets (Security precaution)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
*.cert

# Python byte-compiled / optimized / DLL files (from local python dev servers)
__pycache__/
*.py[codz]
*$py.class

# Operating System Files
# macOS
.DS_Store
.localized
__MACOSX/
.AppleDouble
.LSOverride
Icon[]
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.com.apple.timemachine.supported

# Windows
Thumbs.db
Ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
*.kate-swp
.directory
.Trash-*

# Editor/IDEs Configurations
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-workspace

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr
